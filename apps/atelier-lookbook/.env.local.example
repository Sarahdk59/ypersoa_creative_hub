# apps/atelier-lookbook — variables d'environnement
# Copier en `.env.local` (gitignoré) et renseigner les valeurs réelles.

# ─── IA génératives ──────────────────────────────────────────────
# OpenAI (décomposition brief poétique → prompts EN structurés)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxx

# Google Gemini (génération images)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxx

# ─── Supabase (projet ypersoa-hub partagé) ───────────────────────
# Table `lookbooks` + bucket `lookbook-images`
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ─── URLs des apps voisines ──────────────────────────────────────
# Retour vers le hub atelier-social
NEXT_PUBLIC_SOCIAL_URL=http://localhost:3000
