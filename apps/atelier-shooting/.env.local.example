# apps/atelier-shooting — variables d'environnement
# Copier en `.env.local` (gitignoré) et renseigner les valeurs réelles.
#
# ⚠️ SÉCURITÉ : Vite expose toutes les variables `VITE_*` au bundle client.
# OK en local-only (poste Sarah). En prod publique, déplacer derrière un proxy
# backend (cf. docs/HANDOFF_KEYVAN.md).

# ─── Gemini (génération images via @google/genai) ────────────────
# https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxx

# ─── Supabase (projet ypersoa-hub) ───────────────────────────────
# Partagé avec atelier-social pour le flux : likes Shooting → captions RS
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ─── URL du Hub (atelier-social) ─────────────────────────────────
# Pour la navigation retour + lecture des référentiels via API
VITE_HUB_URL=http://localhost:3000
