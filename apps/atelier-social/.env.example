# apps/atelier-social — variables d'environnement
# Copier en `.env.local` (gitignoré) et renseigner les valeurs réelles.
# Cf. README racine + docs/HANDOFF_KEYVAN.md pour le contexte hébergement.

# ─── IA génératives ──────────────────────────────────────────────
# OpenAI (gpt-4o pour caption Insta + hooks éditoriaux brand-safe FR)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxx

# Google Gemini (images via Nano Banana / Gemini 3 Pro, vidéos via Veo 3.1)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxx

# Moteur de génération vidéo actif pour Atelier Motion
# Valeurs : "veo-3.1" (stable) | "omni-flash" (preview, API dev) | "stub" (sans API, dev local)
ATELIER_MOTION_ENGINE=veo-3.1

# ─── Supabase (projet ypersoa-hub) ───────────────────────────────
# Partagé avec les autres apps (mediatheque, planable, lookbook, shooting).
# URL et anon key sont publiques (préfixe NEXT_PUBLIC_), exposées au browser.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ─── URLs des apps voisines (pour les liens cross-app du Hub) ────
# En dev local, ports par défaut. En prod, remplacer par les domaines déployés.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SHOOTING_URL=http://localhost:3001
NEXT_PUBLIC_PLANABLE_URL=http://localhost:3002
NEXT_PUBLIC_LOOKBOOK_URL=http://localhost:3003
