# apps/planable-ypersoa — variables d'environnement
# Copier en `.env.local` (gitignoré) et renseigner les valeurs réelles.

# ─── Supabase (projet ypersoa-hub) ───────────────────────────────
# Tables : planable_occasions, planable_calendar_entries, planable_packs, planable_post_metrics
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=

# ─── Lien vers atelier-social (génération packs V1.1) ────────────
NEXT_PUBLIC_ATELIER_SOCIAL_URL=http://localhost:3000

# Token interne pour les appels server-to-server (atelier-social → planable)
# Générer une chaîne aléatoire (ex : openssl rand -hex 32)
INTERNAL_API_TOKEN=

# ─── Meta Graph API (V1.2 — publication Instagram automatique) ───
META_GRAPH_API_VERSION=v21.0
META_LONG_LIVED_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
META_APP_SECRET=

# ─── Pinterest (V2) ──────────────────────────────────────────────
PINTEREST_ACCESS_TOKEN=

# ─── Timezone (fixe pour l'atelier Wattrelos) ────────────────────
TZ=Europe/Paris
