  .dark-section .inspi-sec-num { color: #E8937A; }
  .inspi-sec-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 300; line-height: 1.05; letter-spacing: -0.01em; }
  .inspi-sec-title em { font-style: italic; color: var(--terracotta); }
  .dark-section .inspi-sec-title em { color: #E8937A; }
  .inspi-sec-hint { margin-top: 0.8rem; font-size: 0.82rem; line-height: 1.7; opacity: 0.5; }
  .inspi-sec-cta { margin-top: 1.5rem; display: inline-flex; align-items: center; font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--terracotta); text-decoration: none; border-bottom: 1px solid var(--terracotta); padding-bottom: 3px; font-weight: 500; }
  .dark-section .inspi-sec-cta { color: #E8937A; border-bottom-color: #E8937A; }
  .tags-cloud { display: flex; flex-wrap: wrap; gap: 8px; align-content: start; }
  .copy-hint-label { width: 100%; font-size: 0.65rem; opacity: 0.4; letter-spacing: 0.1em; margin-bottom: 0.4rem; display: flex; align-items: center; gap: 6px; }
  .copy-hint-label::before { content: '→'; color: var(--terracotta); }
  .dark-section .copy-hint-label { color: rgba(245,240,232,0.4); }
  .itag { padding: 8px 18px; border: 1px solid var(--cream-dark); font-size: 0.85rem; font-family: 'Cormorant Garamond', serif; font-style: italic; cursor: pointer; transition: all 0.25s; background: transparent; color: var(--ink); position: relative; overflow: hidden; user-select: none; }
  .itag::before { content: ''; position: absolute; inset: 0; background: var(--terracotta); transform: translateX(-100%); transition: transform 0.3s ease; }
  .itag:hover::before { transform: translateX(0); }
  .itag:hover { color: white; border-color: var(--terracotta); }
  .itag span { position: relative; z-index: 1; }
  .dark-section .itag { border-color: rgba(245,240,232,0.15); color: #F5F0EA; }
  .itag.featured { background: var(--terracotta); color: white; border-color: var(--terracotta); font-style: normal; font-family: 'DM Sans', sans-serif; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; cursor: default; }
  .itag.featured::before { display: none; }
  .itag.copied::after { content: '✓ copié'; position: absolute; inset: 0; background: #8A9E8C; display: flex; align-items: center; justify-content: center; font-family: 'DM Sans', sans-serif; font-style: normal; font-size: 0.7rem; letter-spacing: 0.1em; color: white; z-index: 2; }
  .inspi-quote-band { background: var(--terracotta); padding: 3rem 3rem; text-align: center; }
  .inspi-quote-band blockquote { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.4rem, 3vw, 2.2rem); font-weight: 300; font-style: italic; color: white; max-width: 680px; margin: 0 auto; line-height: 1.25; }

  @media (max-width: 900px) {
