<script>
  function showArticle(id) {
    document.getElementById('blogIndex').classList.add('hidden');
    document.querySelectorAll('.article-page').forEach(function(p) { p.classList.remove('active'); });
    document.getElementById(id).classList.add('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  function showIndex() {
    document.getElementById('blogIndex').classList.remove('hidden');
    document.querySelectorAll('.article-page').forEach(function(p) { p.classList.remove('active'); });
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  function copyItag(el) {
    var text = el.querySelector('span') ? el.querySelector('span').textContent : el.textContent.trim();
    navigator.clipboard.writeText(text).then(function() {
      el.classList.add('copied');
      setTimeout(function() { el.classList.remove('copied'); }, 1800);
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    var inspiSections = document.querySelectorAll('.inspi-section[id]');
    var inspiTabs = document.querySelectorAll('.inspi-cat-tab');
    if (inspiSections.length > 0 && typeof IntersectionObserver !== 'undefined') {
      var inspiObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            inspiTabs.forEach(function(t) { t.classList.remove('active'); });
            var active = document.querySelector('.inspi-cat-tab[href="#' + entry.target.id + '"]');
            if (active) active.classList.add('active');
          }
        });
      }, { threshold: 0.3 });
      inspiSections.forEach(function(s) { inspiObserver.observe(s); });
    }
  });
</script>

