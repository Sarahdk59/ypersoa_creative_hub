{% comment %}
  perso-ypm001.liquid — YPM-001 La Brigitte
  Famille  : Cœurs · 1 initiale + couleur fil
  Module   : ypersoa-poignet-addon (option poignet +6€)
{% endcomment %}

{% assign ypersoa_palette = "Blanc|#FFFFFF,Ivoire|#F5F0E0,Gris clair|#C8C8C8,Gris|#A0A0A0,Anthracite|#4A4A4A,Noir|#1A1A1A,Marine|#1E2D4A,Bleu roi|#1A3A8F,Bleu glacier|#8AAFD4,Canard|#1A6670,Vert jade|#1A7A6E,Vert jardin|#7A9E7E,Bordeaux|#6B1E2E,Rouge|#C0392B,Rose pâle|#F0B8C0,Framboise|#C4294E,Lilas|#B8A0C8,Sable|#D4C4A8,Terracotta|#C4694A,Camel|#A0785A" | split: "," %}

<div class="yp-perso-premium" data-motif="YPM-001">

  <div class="yp-perso-premium__header">
    <svg class="yp-perso-premium__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
    </svg>
    <h3 class="yp-perso-premium__title">créez votre broderie</h3>
    <span class="yp-perso-premium__badge">La Brigitte</span>
  </div>

  <div class="yp-perso-premium__content">

    <!-- ① Initiale buste -->
    <div class="yp-step">
      <div class="yp-step__header">
        <span class="yp-step__number">1</span>
        <label class="yp-step__label" for="ypm001-initiale">
          ton initiale
          <span class="yp-step__hint">· 1 lettre · A à Z</span>
        </label>
      </div>
      <div class="ypm001-char-wrap">
        <input
          class="ypm001-char-input perso-input--char"
          type="text"
          id="ypm001-initiale"
          name="properties[Initiale buste]"
          maxlength="1"
          placeholder="M"
          autocomplete="off" autocorrect="off" spellcheck="false"
          required aria-required="true"
        >
        <span class="ypm001-char-preview" aria-hidden="true" id="ypm001-initiale-preview"></span>
      </div>
      <p class="yp-perso-tip">Majuscule automatique · le cœur est brodé au-dessus de ton initiale</p>
    </div>

    <!-- ② Couleur de fils buste -->
    <div class="yp-step">
      <div class="yp-step__header">
        <span class="yp-step__number">2</span>
        <label class="yp-step__label">couleur de fils</label>
      </div>
      <div class="yp-color-grid" role="group" aria-label="Couleur de fils">
        {% for couleur in ypersoa_palette %}
          {% assign parts = couleur | split: "|" %}
          <label class="yp-color-swatch-wrap" title="{{ parts[0] }}">
            <input type="radio" class="sr-only"
              name="properties[Couleur fil buste]"
              value="{{ parts[0] | escape }}"
              {% if forloop.first %}checked{% endif %}
              required>
            <span class="yp-color-swatch{% if parts[0] == 'Blanc' or parts[0] == 'Ivoire' %} yp-color-swatch--light{% endif %}" style="background-color: {{ parts[1] }};"></span>
          </label>
        {% endfor %}
      </div>
      <p class="yp-color-selected-name" id="ypm001-color-name">Blanc</p>
    </div>

    <!-- ③ Option poignet +6€ — masqué si produit tagué yp-019 (t-shirt) -->
    {%- unless product.tags contains 'yp-019' -%}
    <div class="yp-step yp-step--addon">
      <label class="ypm001-addon-toggle" for="ypm001-poignet-toggle">
        <input type="checkbox" id="ypm001-poignet-toggle" aria-controls="ypm001-poignet-fields">
        <span class="ypm001-addon-toggle__icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
        </span>
        <span class="ypm001-addon-toggle__text">
          Ajouter la broderie poignet gauche
          <strong>+6,00 €</strong>
        </span>
      </label>
    </div>
    {%- endunless -%}

    <!-- Champs poignet (masqués par défaut) -->
    {%- unless product.tags contains 'yp-019' -%}
    <div id="ypm001-poignet-fields" class="yp-step yp-step--poignet-fields" hidden aria-hidden="true">

      <!-- A — Symbole poignet -->
      <div class="yp-step__header">
        <span class="yp-step__number">A</span>
        <label class="yp-step__label">symbole poignet
          <span class="yp-step__hint">· optionnel</span>
        </label>
      </div>
      <div class="ypm001-symbol-grid" role="group" aria-label="Symbole poignet">
        <label class="ypm001-symbol-card" title="Aucun">
          <input type="radio" class="sr-only" name="properties[Symbole poignet]" value="Aucun" checked disabled>
          <span class="ypm001-symbol-card__inner">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3"><line x1="5" y1="5" x2="19" y2="19"/><line x1="19" y1="5" x2="5" y2="19"/></svg>
            <span class="ypm001-symbol-card__name">Aucun</span>
          </span>
        </label>
        <label class="ypm001-symbol-card" title="Cœur contour">
          <input type="radio" class="sr-only" name="properties[Symbole poignet]" value="Cœur contour" disabled>
          <span class="ypm001-symbol-card__inner">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            <span class="ypm001-symbol-card__name">Contour</span>
          </span>
        </label>
        <label class="ypm001-symbol-card" title="Cœur plein">
          <input type="radio" class="sr-only" name="properties[Symbole poignet]" value="Cœur plein" disabled>
          <span class="ypm001-symbol-card__inner">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            <span class="ypm001-symbol-card__name">Plein</span>
          </span>
        </label>
      </div>

      <!-- B — Initiale poignet -->
      <div class="yp-step__header" style="margin-top: 18px;">
        <span class="yp-step__number">B</span>
        <label class="yp-step__label" for="ypm001-initiale-poignet">
          initiale poignet
          <span class="yp-step__hint">· 1 lettre · A à Z · optionnelle</span>
        </label>
      </div>
      <div class="ypm001-char-wrap">
        <input
          class="ypm001-char-input perso-input--char"
          type="text"
          id="ypm001-initiale-poignet"
          name="properties[Initiale poignet]"
          maxlength="1"
          placeholder="M"
          autocomplete="off" autocorrect="off" spellcheck="false"
          disabled>
        <span class="ypm001-char-preview" aria-hidden="true" id="ypm001-initiale-poignet-preview"></span>
      </div>
      <p class="yp-perso-tip">Laisse vide si tu veux uniquement le symbole</p>

      <!-- C — Couleur de fils poignet -->
      <div class="yp-step__header" style="margin-top: 18px;">
        <span class="yp-step__number">C</span>
        <label class="yp-step__label">couleur de fils poignet</label>
      </div>
      <div class="yp-color-grid" role="group" aria-label="Couleur de fils poignet">
        {% for couleur in ypersoa_palette %}
          {% assign parts = couleur | split: "|" %}
          <label class="yp-color-swatch-wrap" title="{{ parts[0] }}">
            <input type="radio" class="sr-only"
              name="properties[Couleur fil poignet]"
              value="{{ parts[0] | escape }}"
              {% if forloop.first %}checked{% endif %}
              disabled>
            <span class="yp-color-swatch{% if parts[0] == 'Blanc' or parts[0] == 'Ivoire' %} yp-color-swatch--light{% endif %}" style="background-color: {{ parts[1] }};"></span>
          </label>
        {% endfor %}
      </div>
      <p class="yp-color-selected-name" id="ypm001-poignet-color-name">Blanc</p>

    </div>
    {%- endunless -%}

  </div>
</div>

<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap');

/* ── Design system partagé YPM (copié depuis product-personalization) ── */
.yp-perso-premium { margin: 24px 0; border: 1px solid #D9D1C7; border-radius: 12px; background: #FAF8F5; overflow: hidden; }
.yp-perso-premium__header { display: flex; align-items: center; gap: 12px; padding: 14px 18px; background: #F5F0E8; border-bottom: 1px solid #D9D1C7; }
.yp-perso-premium__icon { width: 22px; height: 22px; color: #C4694A; flex-shrink: 0; }
.yp-perso-premium__title { margin: 0; font-size: 14px; font-weight: 600; color: #1E2D4A; flex: 1; text-transform: lowercase; letter-spacing: 0.01em; }
.yp-perso-premium__badge { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; color: #C4694A; background: #fff; padding: 3px 8px; border-radius: 20px; border: 1px solid #C4694A; text-transform: uppercase; }

.yp-perso-premium__content { padding: 20px 18px; display: flex; flex-direction: column; gap: 20px; }

.yp-step__header { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
.yp-step__number { display: flex; align-items: center; justify-content: center; width: 20px; height: 20px; background: #1E2D4A; color: #fff; font-size: 11px; font-weight: 700; border-radius: 50%; flex-shrink: 0; }
.yp-step__label { font-size: 13px; font-weight: 600; color: #1E2D4A; margin: 0; cursor: pointer; text-transform: lowercase; }
.yp-step__hint { font-weight: 400; font-size: 12px; color: #9E9086; }

/* ── Input initiale ── */
.ypm001-char-wrap { display: flex; align-items: center; gap: 12px; }
.ypm001-char-input {
  width: 72px; height: 72px;
  border: 1.5px solid #D9D1C7; border-radius: 10px;
  background: #fff;
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 36px; font-weight: 700;
  color: #1E2D4A;
  text-align: center; text-transform: uppercase;
  transition: border-color 0.2s, box-shadow 0.2s;
  -webkit-appearance: none;
}
.ypm001-char-input::placeholder { color: #D9D1C7; font-size: 32px; }
.ypm001-char-input:focus { outline: none; border-color: #C4694A; box-shadow: 0 0 0 3px rgba(196,105,74,0.12); }
.ypm001-char-input:not(:placeholder-shown) { border-color: #1E2D4A; }

.ypm001-char-preview { display: none; }

.yp-perso-tip { font-size: 11px; color: #9E9086; margin: 8px 0 0; line-height: 1.5; }

/* ── Color swatches ── */
.yp-color-grid { display: flex; flex-wrap: wrap; gap: 8px; }
.yp-color-swatch-wrap { cursor: pointer; position: relative; }
.yp-color-swatch-wrap .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
.yp-color-swatch { display: block; width: 34px; height: 34px; border-radius: 50%; border: 2px solid transparent; transition: transform 0.15s ease, box-shadow 0.15s ease; }
.yp-color-swatch--light { box-shadow: inset 0 0 0 1px #E0D8D0; }
.yp-color-swatch-wrap input:checked + .yp-color-swatch { transform: scale(1.1); box-shadow: 0 0 0 2px #fff, 0 0 0 4px #C4694A; }
.yp-color-swatch-wrap:hover .yp-color-swatch { transform: scale(1.08); }

.yp-color-selected-name { font-size: 12px; color: #9E9086; margin: 8px 0 0; text-transform: lowercase; letter-spacing: 0.02em; }

/* ── Option poignet ── */
.yp-step--addon { border-top: 1px solid #E8E2DC; padding-top: 18px; margin-top: -4px; }
.ypm001-addon-toggle { display: flex; align-items: center; gap: 12px; cursor: pointer; }
.ypm001-addon-toggle input[type="checkbox"] { position: absolute; opacity: 0; width: 0; height: 0; }
.ypm001-addon-toggle__icon {
  display: flex; align-items: center; justify-content: center;
  width: 32px; height: 32px; flex-shrink: 0;
  border: 1.5px solid #D9D1C7; border-radius: 8px;
  background: #fff; color: #9E9086;
  transition: all 0.2s ease;
}
.ypm001-addon-toggle input:checked ~ .ypm001-addon-toggle__icon { border-color: #C4694A; background: #FFF9F7; color: #C4694A; }
.ypm001-addon-toggle input:checked ~ .ypm001-addon-toggle__icon svg { transform: rotate(45deg); }
.ypm001-addon-toggle__icon svg { transition: transform 0.2s ease; }
.ypm001-addon-toggle__text { font-size: 13px; color: #1E2D4A; font-weight: 500; line-height: 1.4; }
.ypm001-addon-toggle__text strong { display: block; font-size: 12px; color: #C4694A; font-weight: 600; margin-top: 1px; }

.yp-step--poignet-fields { border-left: 2px solid #F0EBE4; padding-left: 14px; margin-left: 4px; }

/* ── Symboles poignet ── */
.ypm001-symbol-grid { display: flex; gap: 8px; }
.ypm001-symbol-card { cursor: pointer; flex: 1; max-width: 88px; }
.ypm001-symbol-card .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
.ypm001-symbol-card__inner {
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  padding: 10px 8px 8px;
  background: #fff; border: 1.5px solid #E8E2DC; border-radius: 10px;
  color: #1E2D4A;
  transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
}
.ypm001-symbol-card input:checked + .ypm001-symbol-card__inner {
  border-color: #C4694A; background: #FFF9F7; color: #C4694A;
  box-shadow: 0 0 0 1px #C4694A;
}
.ypm001-symbol-card:hover .ypm001-symbol-card__inner { border-color: #C4694A; }
.ypm001-symbol-card__name { font-size: 0.65rem; font-weight: 500; letter-spacing: 0.04em; color: inherit; opacity: 0.7; }
</style>

<script>
(function () {
  /* Fonctionne en chargement normal ET en quick-view AJAX
     (DOMContentLoaded peut déjà être passé dans ce cas) */
  function initYPM001() {

    /* ── Initiale buste : forçage A-Z + preview ── */
    var bustInput   = document.getElementById('ypm001-initiale');
    var bustPreview = document.getElementById('ypm001-initiale-preview');
    if (bustInput && !bustInput._ypmInit) {
      bustInput._ypmInit = true;
      bustInput.addEventListener('input', function () {
        this.value = this.value.toUpperCase().replace(/[^A-Z]/g, '');
        if (bustPreview) bustPreview.textContent = this.value;
      });
      bustInput.addEventListener('keypress', function (e) {
        if (!/[A-Za-z]/.test(String.fromCharCode(e.which || e.keyCode))) e.preventDefault();
      });
    }

    /* ── Toggle poignet (auto-contenu, sans dépendance module) ── */
    var toggle = document.getElementById('ypm001-poignet-toggle');
    var panel  = document.getElementById('ypm001-poignet-fields');
    if (toggle && panel && !toggle._ypmInit) {
      toggle._ypmInit = true;

      function applyPanel(active) {
        panel.hidden = !active;
        panel.setAttribute('aria-hidden', String(!active));
        panel.querySelectorAll('input, select').forEach(function (el) {
          el.disabled = !active;
          /* Seule la couleur (radio) est obligatoire — initiale et symbole sont libres */
          if (el.type === 'text') el.required = false;
        });
        /* Initiale poignet : forçage A-Z */
        var poignetInput   = document.getElementById('ypm001-initiale-poignet');
        var poignetPreview = document.getElementById('ypm001-initiale-poignet-preview');
        if (active && poignetInput && !poignetInput._ypmInit) {
          poignetInput._ypmInit = true;
          poignetInput.addEventListener('input', function () {
            this.value = this.value.toUpperCase().replace(/[^A-Z]/g, '');
            if (poignetPreview) poignetPreview.textContent = this.value;
          });
          poignetInput.addEventListener('keypress', function (e) {
            if (!/[A-Za-z]/.test(String.fromCharCode(e.which || e.keyCode))) e.preventDefault();
          });
          poignetInput.focus();
        }
      }

      toggle.addEventListener('change', function () { applyPanel(this.checked); });
      applyPanel(toggle.checked); /* état initial */
    }

    /* ── Nom couleur sélectionnée ── */
    function bindColorName(groupName, displayId) {
      var display = document.getElementById(displayId);
      if (!display || display._ypmBound) return;
      display._ypmBound = true;
      document.querySelectorAll('[name="' + groupName + '"]').forEach(function (radio) {
        radio.addEventListener('change', function () {
          if (this.checked) display.textContent = this.value;
        });
      });
      var checked = document.querySelector('[name="' + groupName + '"]:checked');
      if (checked) display.textContent = checked.value;
    }
    bindColorName('properties[Couleur fil buste]',   'ypm001-color-name');
    bindColorName('properties[Couleur fil poignet]', 'ypm001-poignet-color-name');

    /* ── AJAX add-on panier via module global (si dispo) ── */
    if (window.YpersoaPoignet && toggle && panel && !toggle._ypmCartInit) {
      toggle._ypmCartInit = true;
      window.YpersoaPoignet.init({
        checkboxId : 'ypm001-poignet-toggle',
        panelId    : 'ypm001-poignet-fields',
        motifId    : 'YPM-001'
      });
    }
  }

  /* Lance immédiatement si DOM prêt, sinon attend DOMContentLoaded */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initYPM001);
  } else {
    initYPM001();
  }
}());
</script>
