{% comment %}
  perso-ypm005.liquid — YPM-005 L'Annonce
  Famille  : Mariage / EVJF · Snippet : perso-arc
  Placement: Mini → centre buste ou buste gauche · Maxi → centre buste uniquement
  Champs   : Taille (Mini/Maxi) + Texte arc (12 maj.) + 2e ligne (12, opt.) + Couleur fil
  Règle    : 1 couleur solidaire — arc et 2ᵉ ligne
  Module   : ypersoa-poignet-addon (option poignet +6€)
{% endcomment %}

{% assign ypersoa_palette = "Blanc|#FFFFFF,Ivoire|#F5F0E0,Gris clair|#C8C8C8,Gris|#A0A0A0,Anthracite|#4A4A4A,Noir|#1A1A1A,Marine|#1E2D4A,Bleu roi|#1A3A8F,Bleu glacier|#8AAFD4,Canard|#1A6670,Vert jade|#1A7A6E,Vert jardin|#7A9E7E,Bordeaux|#6B1E2E,Rouge|#C0392B,Rose pâle|#F0B8C0,Framboise|#C4294E,Lilas|#B8A0C8,Sable|#D4C4A8,Terracotta|#C4694A,Camel|#A0785A" | split: "," %}

<div class="yp-perso-premium" data-motif="YPM-005">

  <div class="yp-perso-premium__header">
    <svg class="yp-perso-premium__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 20 Q12 4 19 20"/>
      <circle cx="12" cy="9" r="1.5" fill="currentColor" stroke="none"/>
    </svg>
    <h3 class="yp-perso-premium__title">créez votre broderie</h3>
    <span class="yp-perso-premium__badge">L'Annonce</span>
  </div>

  <div class="yp-perso-premium__content">

    <!-- ① Taille de la broderie -->
    <div class="yp-step">
      <div class="yp-step__header">
        <span class="yp-step__number">1</span>
        <label class="yp-step__label">taille de la broderie</label>
      </div>
      <div class="ypm005-mode-toggle" role="group" aria-label="Taille de la broderie">
        <label class="ypm005-mode-option">
          <input type="radio" class="sr-only"
            name="properties[Taille broderie]"
            id="ypm005-taille-mini"
            value="Mini"
            checked required>
          <span class="ypm005-mode-option__label">Mini <span class="ypm005-mode-sublabel">~10 cm</span></span>
        </label>
        <label class="ypm005-mode-option">
          <input type="radio" class="sr-only"
            name="properties[Taille broderie]"
            id="ypm005-taille-maxi"
            value="Maxi">
          <span class="ypm005-mode-option__label">Maxi <span class="ypm005-mode-sublabel">grand format</span></span>
        </label>
      </div>
      <p class="ypm005-placement-info" id="ypm005-placement-mini">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="11" r="4"/><path d="M12 2C8.1 2 5 5.1 5 9c0 5.3 7 13 7 13s7-7.7 7-13c0-3.9-3.1-7-7-7z"/></svg>
        Placement : centre buste ou buste gauche
      </p>
      <p class="ypm005-placement-info" id="ypm005-placement-maxi" hidden>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="11" r="4"/><path d="M12 2C8.1 2 5 5.1 5 9c0 5.3 7 13 7 13s7-7.7 7-13c0-3.9-3.1-7-7-7z"/></svg>
        Placement : centre buste uniquement
      </p>
    </div>

    <!-- ② Texte en arc -->
    <div class="yp-step">
      <div class="yp-step__header">
        <span class="yp-step__number">2</span>
        <label class="yp-step__label" for="ypm005-texte-arc">
          texte en arc
          <span class="yp-step__hint">· 12 car. max · majuscules</span>
        </label>
      </div>
      <div class="ypm003-badge-wrap">
        <input
          class="ypm003-badge-input"
          type="text"
          id="ypm005-texte-arc"
          name="properties[Texte arc]"
          maxlength="12"
          placeholder="MAMAN, TEAM, FUTURE…"
          autocomplete="off" autocorrect="off" spellcheck="false"
          required aria-required="true"
        >
        <span class="ypm002-counter" aria-live="polite" id="ypm005-counter-arc">0 / 12</span>
      </div>
    </div>

    <!-- ③ 2ᵉ ligne (optionnelle) -->
    <div class="yp-step">
      <div class="yp-step__header">
        <span class="yp-step__number">3</span>
        <label class="yp-step__label" for="ypm005-ligne2">
          2ᵉ ligne
          <span class="yp-step__hint">· 12 car. max · optionnel</span>
        </label>
      </div>
      <div class="ypm003-badge-wrap">
        <input
          class="ypm002-text-input"
          type="text"
          id="ypm005-ligne2"
          name="properties[2e ligne]"
          maxlength="12"
          placeholder="depuis 2012, de deux, Hope…"
          autocomplete="off" autocorrect="off" spellcheck="false"
        >
        <span class="ypm002-counter" aria-live="polite" id="ypm005-counter-ligne2">0 / 12</span>
      </div>
      <p class="yp-perso-tip">Même couleur que le texte arc · écriture libre</p>
    </div>

    <!-- ④ Couleur de fils -->
    <div class="yp-step">
      <div class="yp-step__header">
        <span class="yp-step__number">4</span>
        <label class="yp-step__label">couleur de fils</label>
      </div>
      <p class="yp-perso-tip" style="margin-bottom: 10px;">S'applique à l'ensemble — arc et 2ᵉ ligne.</p>
      <div class="yp-color-grid" role="group" aria-label="Couleur de fils buste">
        {% for couleur in ypersoa_palette %}
          {% assign parts = couleur | split: "|" %}
          <label class="yp-color-swatch-wrap" title="{{ parts[0] }}">
            <input type="radio" class="sr-only"
              name="properties[Couleur fil]"
              value="{{ parts[0] | escape }}"
              {% if forloop.first %}checked{% endif %} required>
            <span class="yp-color-swatch{% if parts[0] == 'Blanc' or parts[0] == 'Ivoire' %} yp-color-swatch--light{% endif %}" style="background-color: {{ parts[1] }};"></span>
          </label>
        {% endfor %}
      </div>
      <p class="yp-color-selected-name" id="ypm005-color-name">Blanc</p>
    </div>

    <!-- ⑤ Option poignet +6€ -->
    {%- unless product.tags contains 'yp-019' -%}
    <div class="yp-step yp-step--addon">
      <label class="ypm001-addon-toggle" for="ypm005-poignet-toggle">
        <input type="checkbox" id="ypm005-poignet-toggle" aria-controls="ypm005-poignet-fields">
        <span class="ypm001-addon-toggle__icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
        </span>
        <span class="ypm001-addon-toggle__text">
          Ajouter la broderie poignet gauche
          <strong>+6,00 €</strong>
        </span>
      </label>
    </div>

    <div id="ypm005-poignet-fields" class="yp-step yp-step--poignet-fields" hidden aria-hidden="true">

      <!-- ★ Template poignet -->
      <div class="yp-step__header">
        <span class="yp-step__number" style="background:#C4694A;">★</span>
        <label class="yp-step__label">template poignet</label>
      </div>
      <div class="ypm004-template-grid" role="group" aria-label="Template broderie poignet">
        <label class="ypm004-template-card" title="Modèle A — Cœur seul">
          <input type="radio" class="sr-only" name="properties[Template poignet]" value="A — Cœur seul" checked disabled>
          <span class="ypm004-template-card__inner">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="currentColor"><path d="M20 32c-6-5.5-11-9.5-11-14 0-3.5 2.8-5 5-5 1.2 0 3.5.5 6 4.5 2.5-4 4.8-4.5 6-4.5 2.2 0 5 1.5 5 5 0 4.5-5 8.5-11 14z"/></svg>
            <span class="ypm004-template-card__label">A</span>
          </span>
        </label>
        <label class="ypm004-template-card" title="Modèle B — Texte · cœur · texte">
          <input type="radio" class="sr-only" name="properties[Template poignet]" value="B — Texte · cœur · texte" disabled>
          <span class="ypm004-template-card__inner">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <text x="20" y="10" text-anchor="middle" font-size="7" font-weight="700" fill="currentColor" font-family="serif">Romane</text>
              <path d="M20 24c-3.5-3-7-5.5-7-8 0-2 1.6-2.8 3-2.8.7 0 2.2.3 4 2.5 1.8-2.2 3.3-2.5 4-2.5 1.4 0 3 .8 3 2.8 0 2.5-3.5 5-7 8z" fill="currentColor"/>
              <text x="20" y="34" text-anchor="middle" font-size="7" font-weight="700" fill="currentColor" font-family="serif">Maelle</text>
            </svg>
            <span class="ypm004-template-card__label">B</span>
          </span>
        </label>
        <label class="ypm004-template-card" title="Modèle C — Texte + cœur bas">
          <input type="radio" class="sr-only" name="properties[Template poignet]" value="C — Texte + cœur bas" disabled>
          <span class="ypm004-template-card__inner">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <text x="20" y="18" text-anchor="middle" font-size="9" font-weight="700" fill="currentColor" font-family="serif">Emma</text>
              <path d="M20 34c-3-2.8-6-5-6-7 0-1.8 1.4-2.5 2.6-2.5.7 0 2 .3 3.4 2.2 1.4-1.9 2.7-2.2 3.4-2.2 1.2 0 2.6.7 2.6 2.5 0 2-3 4.2-6 7z" fill="none" stroke="currentColor" stroke-width="1.2"/>
            </svg>
            <span class="ypm004-template-card__label">C</span>
          </span>
        </label>
        <label class="ypm004-template-card" title="Modèle D — Cœur + initiale">
          <input type="radio" class="sr-only" name="properties[Template poignet]" value="D — Cœur + initiale" disabled>
          <span class="ypm004-template-card__inner">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <path d="M14 26c-4-3.5-8-6.5-8-9.5 0-2.4 1.8-3.2 3.4-3.2.8 0 2.5.4 4.6 2.8 2.1-2.4 3.8-2.8 4.6-2.8 1.6 0 3.4.8 3.4 3.2 0 3-4 6-8 9.5z" fill="currentColor"/>
              <text x="30" y="26" text-anchor="middle" font-size="16" font-weight="700" fill="currentColor" font-family="serif">E</text>
            </svg>
            <span class="ypm004-template-card__label">D</span>
          </span>
        </label>
      </div>
      <p class="yp-perso-tip" style="margin-top: 8px;">Le modèle détermine la mise en page de ta broderie poignet.</p>

      <!-- A — Texte poignet -->
      <div class="yp-step__header" style="margin-top: 18px;">
        <span class="yp-step__number">A</span>
        <label class="yp-step__label" for="ypm005-texte-poignet">
          texte poignet
          <span class="yp-step__hint">· 10 car. / ligne · 3 lignes max</span>
        </label>
      </div>
      <div class="ypm002-poignet-input-wrap">
        <input
          class="ypm002-text-input perso-input--text"
          type="text"
          id="ypm005-texte-poignet"
          name="properties[Texte poignet]"
          maxlength="32"
          placeholder="Léa, Maman…"
          autocomplete="off" autocorrect="off" spellcheck="false"
          disabled>
      </div>
      <div class="ypm002-lines-preview" id="ypm005-lines-preview" aria-live="polite"></div>
      <p class="yp-perso-tip">Virgule ou espace = passage à la ligne · 10 car. max · 3 lignes maximum</p>

      <!-- B — Couleur de fils poignet -->
      <div class="yp-step__header" style="margin-top: 18px;">
        <span class="yp-step__number">B</span>
        <label class="yp-step__label">couleur de fils</label>
      </div>
      <div class="yp-color-grid" role="group" aria-label="Couleur fil poignet">
        {% for couleur in ypersoa_palette %}
          {% assign parts = couleur | split: "|" %}
          <label class="yp-color-swatch-wrap" title="{{ parts[0] }}">
            <input type="radio" class="sr-only"
              name="properties[Couleur fil poignet]"
              value="{{ parts[0] | escape }}"
              {% if forloop.first %}checked{% endif %}
              disabled>
            <span class="yp-color-swatch{% if parts[0] == 'Blanc' or parts[0] == 'Ivoire' %} yp-color-swatch--light{% endif %}" style="background-color: {{ parts[1] }};"></span>
          </label>
        {% endfor %}
      </div>
      <p class="yp-color-selected-name" id="ypm005-poignet-fil-name">Blanc</p>

    </div>
    {%- endunless -%}

  </div>
</div>

<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap');

/* ── Design system partagé YPM ── */
.yp-perso-premium { margin: 24px 0; border: 1px solid #D9D1C7; border-radius: 12px; background: #FAF8F5; overflow: hidden; }
.yp-perso-premium__header { display: flex; align-items: center; gap: 12px; padding: 14px 18px; background: #F5F0E8; border-bottom: 1px solid #D9D1C7; }
.yp-perso-premium__icon { width: 22px; height: 22px; color: #C4694A; flex-shrink: 0; }
.yp-perso-premium__title { margin: 0; font-size: 14px; font-weight: 600; color: #1E2D4A; flex: 1; text-transform: lowercase; letter-spacing: 0.01em; }
.yp-perso-premium__badge { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; color: #C4694A; background: #fff; padding: 3px 8px; border-radius: 20px; border: 1px solid #C4694A; text-transform: uppercase; }
.yp-perso-premium__content { padding: 20px 18px; display: flex; flex-direction: column; gap: 20px; }

.yp-step__header { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
.yp-step__number { display: flex; align-items: center; justify-content: center; width: 20px; height: 20px; background: #1E2D4A; color: #fff; font-size: 11px; font-weight: 700; border-radius: 50%; flex-shrink: 0; }
.yp-step__label { font-size: 13px; font-weight: 600; color: #1E2D4A; margin: 0; cursor: pointer; text-transform: lowercase; }
.yp-step__hint { font-weight: 400; font-size: 12px; color: #9E9086; }
.yp-perso-tip { font-size: 11px; color: #9E9086; margin: 8px 0 0; line-height: 1.5; }

/* ── Palette couleurs ── */
.yp-color-grid { display: flex; flex-wrap: wrap; gap: 6px; }
.yp-color-swatch-wrap { cursor: pointer; }
.yp-color-swatch-wrap .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
.yp-color-swatch { display: block; width: 26px; height: 26px; border-radius: 50%; box-shadow: inset 0 0 0 1.5px rgba(0,0,0,0.08); transition: transform 0.12s, box-shadow 0.12s; }
.yp-color-swatch--light { box-shadow: inset 0 0 0 1.5px #D9D1C7; }
.yp-color-swatch-wrap input:checked + .yp-color-swatch { transform: scale(1.18); box-shadow: 0 0 0 2px #fff, 0 0 0 4px #C4694A; }
.yp-color-swatch-wrap:hover .yp-color-swatch { transform: scale(1.1); }
.yp-color-selected-name { font-size: 11px; color: #9E9086; margin: 8px 0 0; min-height: 16px; }

/* ── Option poignet ── */
.yp-step--addon { padding-top: 6px; border-top: 1px dashed #E0D8D0; }
.ypm001-addon-toggle { display: flex; align-items: flex-start; gap: 10px; cursor: pointer; }
.ypm001-addon-toggle input[type="checkbox"] { width: 16px; height: 16px; margin-top: 2px; accent-color: #C4694A; flex-shrink: 0; cursor: pointer; }
.ypm001-addon-toggle__icon { display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: #F5F0E8; border-radius: 50%; color: #C4694A; flex-shrink: 0; }
.ypm001-addon-toggle__text { font-size: 13px; color: #1E2D4A; font-weight: 500; line-height: 1.4; }
.ypm001-addon-toggle__text strong { display: block; font-size: 12px; color: #C4694A; font-weight: 600; margin-top: 1px; }
.yp-step--poignet-fields { border-left: 2px solid #F0EBE4; padding-left: 14px; margin-left: 4px; }

/* ── Badge input (Playfair varsity) ── */
.ypm003-badge-wrap { position: relative; }
.ypm003-badge-input {
  display: block; width: 100%; height: 48px;
  padding: 0 52px 0 14px;
  font-family: 'Playfair Display', Georgia, serif; font-size: 18px; font-weight: 700; letter-spacing: 0.04em;
  border: 1.5px solid #D9D1C7; border-radius: 8px; background: #fff; color: #1E2D4A;
  outline: none; transition: border-color 0.15s, box-shadow 0.15s;
}
.ypm003-badge-input:focus { border-color: #C4694A; box-shadow: 0 0 0 3px rgba(196,105,74,0.12); }
.ypm003-badge-input::placeholder { color: #D9D1C7; font-weight: 400; font-size: 14px; letter-spacing: 0; }
.ypm002-text-input {
  display: block; width: 100%; height: 44px;
  padding: 0 52px 0 14px;
  font-size: 15px; font-weight: 500; letter-spacing: 0.01em;
  border: 1.5px solid #D9D1C7; border-radius: 8px; background: #fff; color: #1E2D4A;
  outline: none; transition: border-color 0.15s, box-shadow 0.15s;
}
.ypm002-text-input:focus { border-color: #C4694A; box-shadow: 0 0 0 3px rgba(196,105,74,0.12); }
.ypm002-text-input::placeholder { color: #D9D1C7; font-size: 13px; font-weight: 400; }
.ypm002-counter { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); font-size: 11px; color: #B8AFA8; pointer-events: none; }

/* ── Taille Mini / Maxi toggle ── */
.ypm005-mode-toggle { display: flex; gap: 8px; margin-bottom: 10px; }
.ypm005-mode-option { cursor: pointer; flex: 1; }
.ypm005-mode-option .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
.ypm005-mode-option__label {
  display: block; padding: 9px 14px; text-align: center;
  font-size: 13px; font-weight: 600; color: #1E2D4A;
  border: 1.5px solid #D9D1C7; border-radius: 8px; background: #fff;
  transition: border-color 0.15s, background 0.15s, color 0.15s;
  line-height: 1.3;
}
.ypm005-mode-option input:checked + .ypm005-mode-option__label {
  border-color: #1E2D4A; background: #1E2D4A; color: #fff;
}
.ypm005-mode-option:hover .ypm005-mode-option__label { border-color: #1E2D4A; color: #1E2D4A; }
.ypm005-mode-sublabel { display: block; font-size: 10px; font-weight: 400; opacity: 0.75; margin-top: 1px; }
.ypm005-mode-option input:checked + .ypm005-mode-option__label .ypm005-mode-sublabel { opacity: 0.8; }

/* ── Placement dynamique ── */
.ypm005-placement-info {
  display: flex; align-items: center; gap: 6px;
  font-size: 11px; color: #9E9086; margin: 0;
  padding: 7px 10px;
  background: #F5F0E8; border-radius: 6px;
}
.ypm005-placement-info svg { color: #C4694A; flex-shrink: 0; }

/* ── Template poignet (4 cartes) ── */
.ypm004-template-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
.ypm004-template-card { cursor: pointer; }
.ypm004-template-card .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
.ypm004-template-card__inner { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 10px 4px 8px; background: #fff; border: 1.5px solid #E8E2DC; border-radius: 10px; color: #1E2D4A; transition: border-color 0.15s, background 0.15s, color 0.15s; }
.ypm004-template-card input:checked + .ypm004-template-card__inner { border-color: #C4694A; background: #FFF9F7; color: #C4694A; box-shadow: 0 0 0 1px #C4694A; }
.ypm004-template-card:hover .ypm004-template-card__inner { border-color: #C4694A; }
.ypm004-template-card__label { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.06em; color: inherit; text-transform: uppercase; }

/* ── Preview lignes poignet ── */
.ypm002-poignet-input-wrap { position: relative; }
.ypm002-lines-preview { display: flex; flex-direction: column; gap: 3px; margin: 8px 0 0; }
.ypm002-lines-preview:empty { display: none; }
.ypm002-line-chip { display: inline-flex; align-items: center; gap: 6px; padding: 3px 10px; background: #F5F0E8; border: 1px solid #E0D8D0; border-radius: 6px; font-size: 12px; font-weight: 600; color: #1E2D4A; letter-spacing: 0.04em; max-width: fit-content; }
.ypm002-line-chip__num { font-size: 10px; color: #9E9086; font-weight: 400; }
.ypm002-line-error { display: flex; align-items: center; gap: 6px; margin-top: 4px; padding: 6px 10px; background: #FFF0F0; border: 1px solid #F0C0C0; border-radius: 6px; font-size: 11.5px; color: #B03030; }
</style>

<script>
(function () {
  if (window.__ypInit005) return;
  window.__ypInit005 = true;

  function initYPM005() {

    /* ── Forçage majuscule — champ arc buste uniquement ── */
    ['ypm005-texte-arc'].forEach(function (id) {
      var el = document.getElementById(id);
      if (!el || el._ypm5UpperInit) return;
      el._ypm5UpperInit = true;
      el.addEventListener('input', function () {
        var pos = this.selectionStart;
        this.value = this.value.toUpperCase();
        this.setSelectionRange(pos, pos);
      });
    });

    /* ── Compteurs caractères buste ── */
    [
      ['ypm005-texte-arc',  'ypm005-counter-arc',    12],
      ['ypm005-ligne2',     'ypm005-counter-ligne2', 12]
    ].forEach(function (c) {
      var input   = document.getElementById(c[0]);
      var counter = document.getElementById(c[1]);
      if (!input || !counter || input._ypm5CountInit) return;
      input._ypm5CountInit = true;
      input.addEventListener('input', function () {
        counter.textContent = this.value.length + ' / ' + c[2];
      });
    });

    /* ── Placement dynamique Mini / Maxi ── */
    var miniRadio      = document.getElementById('ypm005-taille-mini');
    var maxiRadio      = document.getElementById('ypm005-taille-maxi');
    var placementMini  = document.getElementById('ypm005-placement-mini');
    var placementMaxi  = document.getElementById('ypm005-placement-maxi');

    function applyTaille() {
      var isMaxi = maxiRadio && maxiRadio.checked;
      if (placementMini) placementMini.hidden = isMaxi;
      if (placementMaxi) placementMaxi.hidden = !isMaxi;
    }
    if (miniRadio && !miniRadio._ypm5TailleInit) {
      miniRadio._ypm5TailleInit = true;
      miniRadio.addEventListener('change', applyTaille);
      maxiRadio.addEventListener('change', applyTaille);
      applyTaille();
    }

    /* ── Nom couleur ── */
    function bindColorName(groupName, displayId) {
      var display = document.getElementById(displayId);
      if (!display || display._ypmBound) return;
      display._ypmBound = true;
      document.querySelectorAll('[name="' + groupName + '"]').forEach(function (r) {
        r.addEventListener('change', function () { if (this.checked) display.textContent = this.value; });
      });
      var checked = document.querySelector('[name="' + groupName + '"]:checked');
      if (checked) display.textContent = checked.value;
    }
    bindColorName('properties[Couleur fil]',         'ypm005-color-name');
    bindColorName('properties[Couleur fil poignet]', 'ypm005-poignet-fil-name');

    /* ── Preview lignes poignet ── */
    function bindLinesPreview(inputId, previewId) {
      var input = document.getElementById(inputId), preview = document.getElementById(previewId);
      if (!input || !preview || input._ypm5LinesInit) return;
      input._ypm5LinesInit = true;
      function render() {
        var parts = input.value.split(/[, ]+/).filter(function (s) { return s.length > 0; });
        preview.innerHTML = '';
        var errors = [];
        parts.forEach(function (line, i) { if (line.length > 10) errors.push('Ligne ' + (i + 1) + ' : ' + line.length + ' car.'); });
        if (parts.length > 3) errors.push('3 lignes max (' + parts.length + ' détectées)');
        parts.slice(0, 3).forEach(function (line, i) {
          var chip = document.createElement('span'); chip.className = 'ypm002-line-chip';
          chip.innerHTML = '<span class="ypm002-line-chip__num">L' + (i + 1) + '</span>' + line;
          preview.appendChild(chip);
        });
        if (errors.length) {
          var err = document.createElement('div'); err.className = 'ypm002-line-error';
          err.textContent = '⚠ ' + errors.join(' · ');
          preview.appendChild(err);
          input.setCustomValidity(errors.join('. '));
        } else { input.setCustomValidity(''); }
      }
      input.addEventListener('input', render);
    }

    /* ── Toggle poignet ── */
    var toggle = document.getElementById('ypm005-poignet-toggle');
    var panel  = document.getElementById('ypm005-poignet-fields');
    if (toggle && panel && !toggle._ypmInit) {
      toggle._ypmInit = true;
      function applyPanel(active) {
        panel.hidden = !active;
        panel.setAttribute('aria-hidden', String(!active));
        panel.querySelectorAll('input').forEach(function (el) { el.disabled = !active; });
        if (active) {
          bindLinesPreview('ypm005-texte-poignet', 'ypm005-lines-preview');
          bindColorName('properties[Couleur fil poignet]', 'ypm005-poignet-fil-name');
          var first = panel.querySelector('input[type="text"]');
          if (first) first.focus();
        }
      }
      toggle.addEventListener('change', function () { applyPanel(this.checked); });
      applyPanel(toggle.checked);
    }

    /* ── Module cart add-on ── */
    if (window.YpersoaPoignet && toggle && panel && !toggle._ypmCartInit) {
      toggle._ypmCartInit = true;
      window.YpersoaPoignet.init({ checkboxId: 'ypm005-poignet-toggle', panelId: 'ypm005-poignet-fields', motifId: 'YPM-005' });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initYPM005);
  } else {
    initYPM005();
  }
}());
</script>
