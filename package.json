{
  "name": "ypersoa-creative-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Hub Ypersoa - Système d'automatisation des métiers de la communication",
  "scripts": {
    "dev:atelier": "pnpm --filter @ypersoa/atelier-social dev",
    "build:atelier": "pnpm --filter @ypersoa/atelier-social build",
    "dev:atelier-shooting": "pnpm --filter @ypersoa/atelier-shooting dev",
    "build:atelier-shooting": "pnpm --filter @ypersoa/atelier-shooting build",
    "dev:planable": "pnpm --filter @ypersoa/planable-ypersoa dev",
    "build:planable": "pnpm --filter @ypersoa/planable-ypersoa build",
    "test:planable": "pnpm --filter @ypersoa/planable-ypersoa test",
    "typecheck:planable": "pnpm --filter @ypersoa/planable-ypersoa type-check"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
